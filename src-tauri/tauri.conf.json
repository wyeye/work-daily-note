{
  "$schema": "https://schema.tauri.app/config/2.11.2",
  "productName": "Work Daily Note",
  "version": "0.1.5",
  "identifier": "com.wyeye.work-daily-note",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "../src/renderer"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Work Daily Note",
        "width": 980,
        "height": 720,
        "minWidth": 860,
        "minHeight": 620,
        "resizable": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "../src/assets/icons/app.png",
      "../src/assets/icons/app-128.png",
      "../src/assets/icons/app-256.png",
      "../src/assets/icons/app.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false
      }
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDkwRTMxODdFM0VBRTk1MUIKUldRYmxhNCtmaGpqa0RWMm9NNWJUVkRyT3R5cEtYNHZhQmE5MW9iV0xVWHpld01MczFyNHpHTFgK",
      "endpoints": [
        "https://github.com/wyeye/work-daily-note/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
